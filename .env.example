# GitHub Copilot API token
GITHUB_TOKEN=

# Picovoice wake-word detection access key
PICOVOICE_ACCESS_KEY=

# ElevenLabs TTS credentials
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Nexus Mods personal API key
NEXUS_MODS_API_KEY=

# SQL Server read-only MCP server
SQL_SERVER_SERVER=.
SQL_SERVER_PORT=
SQL_SERVER_USERNAME=
SQL_SERVER_PASSWORD=
SQL_SERVER_ENCRYPT=true
SQL_SERVER_TRUST_SERVER_CERTIFICATE=false
SQL_SERVER_ALLOWED_DATABASES=
SQL_SERVER_ROW_LIMIT=200
SQL_SERVER_TIMEOUT_MS=10000

# WebSocket server port (default: 9720)
SPIRA_PORT=9720

# Whisper model size: tiny.en | base.en | small.en
WHISPER_MODEL=base.en

# Path to Picovoice wake-word model file (.ppn)
WAKE_WORD_MODEL=assets/wake-word/shinra.ppn
