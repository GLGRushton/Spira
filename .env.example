# GitHub Copilot API token
GITHUB_TOKEN=

# Picovoice wake-word detection access key
PICOVOICE_ACCESS_KEY=

# ElevenLabs TTS credentials
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Nexus Mods personal API key
NEXUS_MODS_API_KEY=

# WebSocket server port (default: 9720)
SPIRA_PORT=9720

# Whisper model size: tiny.en | base.en | small.en
WHISPER_MODEL=base.en

# Path to Picovoice wake-word model file (.ppn)
WAKE_WORD_MODEL=assets/wake-word/shinra.ppn
