{
  "name": "spira",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names renderer,electron --prefix-colors teal,blue \"pnpm --filter @spira/renderer dev\" \"pnpm --filter @spira/main dev\"",
    "dev:backend": "pnpm -F @spira/backend dev",
    "dev:main": "pnpm -F @spira/main dev",
    "dev:renderer": "pnpm -F @spira/renderer dev",
    "dev:mcp-nexus": "pnpm -F @spira/mcp-nexus-mods dev",
    "dev:mcp-memories": "pnpm -F @spira/mcp-memories dev",
    "dev:mcp-spira-data-entry": "pnpm -F @spira/mcp-spira-data-entry dev",
    "dev:mcp-spira-ui": "pnpm -F @spira/mcp-spira-ui dev",
    "dev:mcp-vision": "pnpm -F @spira/mcp-vision dev",
    "dev:mcp-windows": "pnpm -F @spira/mcp-windows dev",
    "typecheck": "tsc --build && tsc --noEmit -p packages/renderer/tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "build": "tsx scripts/build.ts",
    "package": "pnpm wakeword:setup && pnpm build && electron-builder --config apps/desktop/electron-builder.yml",
    "whisper:setup": "npx nodejs-whisper download",
    "wakeword:setup": "powershell -ExecutionPolicy Bypass -File .\\scripts\\setup-openwakeword-runtime.ps1",
    "new-mcp-server": "tsx scripts/new-mcp-server.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "concurrently": "^9.0.0",
    "electron-builder": "^25.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
